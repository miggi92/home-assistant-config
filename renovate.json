{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended"],
	"lockFileMaintenance": {
		"enabled": true,
		"automerge": true
	},
	"packageRules": [
		{
			"matchUpdateTypes": ["minor", "patch"],
			"matchCurrentVersion": "!/^0/",
			"automerge": true
		},
		{
			"matchFileNames": ["docs/**"],
			"groupName": "docs dependencies",
			"labels": ["dependencies", "documentation"],
			"commitMessageTopic": "docs dependencies"
		},
		{
			"matchManagers": ["github-actions"],
			"description": "Group Actions",
			"labels": ["github-actions", "dependencies"],
			"groupName": "github actions",
			"groupSlug": "github-actions"
		},
		{
			"matchFileNames": ["custom_components/**"],
			"groupName": "custom components dependencies",
			"labels": ["dependencies"],
			"commitMessageTopic": "custom components"
		}
	],
	"vulnerabilityAlerts": {
		"enabled": true
	}
}
