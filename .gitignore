# ==============================================================================
# 1. ALLES IGNORIEREN
# ==============================================================================
*

# ==============================================================================
# 2. ORDNER-STRUKTUR ERLAUBEN
# ==============================================================================
# Erlaubt Git, in Ordner zu schauen, um whitelisted Dateien zu finden.
!*/

# ==============================================================================
# 3. PERFORMANCE & SYSTEM-ORDNER SOFORT WIEDER IGNORIEREN
# ==============================================================================
# Diese Ordner werden sofort ausgeschlossen, damit Git sie gar nicht erst
# nach erlaubten Dateien (wie *.json) durchsuchen muss. Das spart enorm Zeit.
.storage/
.cache/
.cloud/
cremalink_tokens/
node_modules/
/www/community/
/www/llmvision/
/media/llmvision/
/www/cams/
/www/images/screenshots/
/www/downloaded/
/www/cam_captures/
/www/mail_and_packages/
/image/
/node-red/
/tts/
/themes/
/zigbee2mqtt/log/
/zha_ota/
/docs/.vitepress/dist/
/docs/.vitepress/cache/

# ==============================================================================
# 4. DATEITYPEN & SPEZIFISCHE DATEIEN ERLAUBEN (WHITELIST)
# ==============================================================================
# Gängige Konfigurations- und Code-Dateien
!*.yaml
!*.yml
!*.md
!*.json
!*.py
!*.js
!*.ts
!*.vue
!*.mts
!*.sh

# Bilder und Medien
!*.png
!*.jpg
!*.jpeg
!*.ico
!*.mp3

# Spezifische Home Assistant & System-Dateien
!.gitignore
!*.repositories
!.yamllint
!.gitkeep
!.HA_VERSION
!bun.lockb
!.npmrc
!/custom_components/

# ==============================================================================
# 5. SENSIBLE & GENERIERTE DATEIEN AUSDRÜCKLICH IGNORIEREN (BLACKLIST)
# ==============================================================================
# Diese Sektion MUSS ganz unten stehen!
# Sie überschreibt die Whitelist von oben (wie !*.yaml oder !*.json),
# damit deine Secrets wirklich sicher bleiben.

# Core Home Assistant Secrets & Datenbanken
secrets.yaml
ip_bans.yaml
known_devices.yaml
google_calendars.yaml
.shopping_list.json
.google.token
home-assistant.log
home-assistant_v2.db
home-assistant_v2.db-shm
home-assistant_v2.db-wal
OZW_Log.txt
.mcp_proxy_config.json

# Spezifische Konfigurationen & Add-on State
skyqDefaultRoom.yaml
/www/logo/work_miguel_logo.svg
zigbee2mqtt/state.json
zigbee2mqtt/configuration.yaml
zigbee2mqtt/coordinator_backup.json#
.device-builder.json

# OS-spezifische unsichtbare Dateien
.DS_Store
Thumbs.db
